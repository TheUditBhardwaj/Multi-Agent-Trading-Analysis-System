# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy this file to `.env` and fill in your values.
# Never commit your real `.env` file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── NVIDIA NIM API Key (required) ────────────────────────────────────────────
# Obtain your free API key at: https://build.nvidia.com/
# The key powers the ChatNVIDIA / stepfun-ai model integration.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LangSmith Tracing (optional — uncomment to enable) ───────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LANGCHAIN_PROJECT=multi-agent-trading-analysis
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
